{
  "entities": {
    "report": {
      "title": "Community Tactical Report",
      "description": "A tactical report shared by a community member about road conditions, borders, etc.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the reporter" },
        "userName": { "type": "string", "description": "Name of the reporter" },
        "pointId": { "type": "string", "description": "ID of the specific point/station" },
        "content": { "type": "string", "description": "The report message" },
        "category": { "type": "string", "description": "Category (segurança, água, etc)" },
        "reportType": { "type": "string", "description": "Specific tactical type (flood, danger, etc)" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED"], "description": "Moderation status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp" }
      },
      "required": ["userName", "content", "createdAt", "status", "pointId"]
    },
    "trackingSession": {
      "title": "GPS Tracking Session",
      "description": "A real-time GPS tracking session for shared safety.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["userId", "lat", "lng", "updatedAt", "active"]
    },
    "savedRoute": {
      "title": "Saved Tactical Route",
      "description": "A route saved by a user for quick access.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who saved the route" },
        "routeId": { "type": "string", "description": "ID of the route" },
        "routeName": { "type": "string", "description": "Name of the route" },
        "savedAt": { "type": "string", "format": "date-time", "description": "Timestamp" }
      },
      "required": ["userId", "routeId", "routeName", "savedAt"]
    }
  },
  "firestore": {
    "reports": {
      "schema": "report",
      "description": "Collection of community reports"
    },
    "trackingSessions": {
      "schema": "trackingSession",
      "description": "Real-time location sharing sessions"
    },
    "savedRoutes": {
      "schema": "savedRoute",
      "description": "Collection of user-saved routes"
    }
  }
}
