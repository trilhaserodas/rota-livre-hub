rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "trilhaserodas@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidTracking(data) {
      return data.keys().hasAll(['userId', 'lat', 'lng', 'updatedAt', 'active']) &&
             data.userId is string &&
             data.lat is number &&
             data.lng is number &&
             data.active is bool &&
             (data.updatedAt == request.time || data.updatedAt is timestamp);
    }

    function isValidReport(data) {
      return data.keys().hasAll(['userName', 'content', 'createdAt', 'status']) &&
             data.keys().size() <= 12 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.content is string && data.content.size() <= 1000 &&
             data.status in ['PENDING', 'APPROVED'] &&
             data.createdAt == request.time;
    }

    function isValidSavedRoute(data) {
      return data.keys().hasAll(['userId', 'routeId', 'routeName', 'savedAt']) &&
             data.userId is string &&
             data.routeId is string &&
             data.routeName is string &&
             data.userId == request.auth.uid &&
             data.savedAt == request.time;
    }

    // Reports collection
    match /reports/{reportId} {
      allow list: if 
        (resource.data.status == 'APPROVED') || // Public see approved
        isAdmin(); // Admin sees all
        
      allow get: if 
        (resource.data.status == 'APPROVED') ||
        isAdmin();

      allow create: if 
        isValidReport(incoming()) && 
        incoming().status == 'PENDING'; // Force pending for public
      
      allow update: if 
        isAdmin() && 
        isValidReport(incoming()); // Only admin can approve (change status)

      allow delete: if isAdmin();
    }

    // Tracking Sessions
    match /trackingSessions/{sessionId} {
      allow get: if true; 
      allow list: if isSignedIn(); // Allow all explorers to see each other
      
      allow create: if isSignedIn() && 
                      isValidTracking(incoming()) && 
                      incoming().userId == request.auth.uid;
      
      allow update: if isSignedIn() && 
                    existing().userId == request.auth.uid && 
                    isValidTracking(incoming()) &&
                    incoming().userId == existing().userId;
                    
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // Saved Routes
    match /savedRoutes/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSavedRoute(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
